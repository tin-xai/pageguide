{
  "manifest_version": 3,
  "name": "XWebAgent",
  "version": "1.0.0",
  "description": "AI Web Assistant - Makes browsing Safe, Fun, and Efficient",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel",
    "offscreen"
  ],
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon128.png",
      "32": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open XWebAgent Chat"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/prompts.js",
        "content/utils.js",
        "content/functions/scroll.js",
        "content/functions/capture_screenshot.js",
        "content/functions/highlight.js",
        "content/functions/highlight_pdf.js",
        "content/functions/main_router.js",
        "content/tasks/ask.js",
        "content/tasks/ask_pdf.js",
        "content/tasks/guide.js",
        "content/tasks/guidev2.js",
        "content/tasks/protection.js",
        "content/tasks/image_ask.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "lib/*", "pdf-viewer/*", "guide_tutorials.json", "user_study_data/*", "user_study_data/find_html/*", "user_study_data/selected_hide_data/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
